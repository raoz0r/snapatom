<Window x:Class="Text_Grab.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sync Type Name" Height="170" Width="380"
        WindowStartupLocation="CenterScreen"
        Background="#18181B" Foreground="#F4F4F5"
        WindowStyle="None" ResizeMode="NoResize"
        AllowsTransparency="True" BorderThickness="1" BorderBrush="#27272A"
        Icon="pack://siteoforigin:,,,/app_icon.png">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <!-- Header/Prompt -->
            <RowDefinition Height="Auto"/>
            <!-- Input TextBox -->
            <RowDefinition Height="*"/>
            <!-- Action Buttons -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10" VerticalAlignment="Center">
            <Image Source="pack://siteoforigin:,,,/app_icon.png" Width="20" Height="20" Margin="0,0,8,0" VerticalAlignment="Center"/>
            <TextBlock Text="Enter Batch Sync Type" FontSize="16" FontWeight="Bold" Foreground="#FAF5FF" VerticalAlignment="Center"/>
        </StackPanel>
        
        <TextBox Grid.Row="1" x:Name="InputTextBox" VerticalAlignment="Center" Height="32" Padding="8,6" Background="#27272A" Foreground="#F4F4F5" BorderBrush="#3F3F46" BorderThickness="1"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Cancel" Width="80" Height="32" Margin="0,0,10,0" Style="{StaticResource SecondaryButton}" Click="Cancel_Click"/>
            <Button Content="Sync" Width="90" Height="32" IsDefault="True" Style="{StaticResource PrimaryButton}" Click="Sync_Click"/>
        </StackPanel>
    </Grid>
</Window>
